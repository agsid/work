---
---
<nav class="sticky top-0 z-50 bg-slate-950/40 backdrop-blur-xl border-b border-slate-800/50 px-6 py-3">
  <div class="max-w-6xl mx-auto flex justify-between items-center">
    
    <div class="flex items-center gap-4">
      <a href="/" class="text-2xl font-black tracking-tighter text-white flex items-center gap-2 hover:text-cyan-400 transition-colors">
        <span class="text-cyan-500">A</span>lliedWork
      </a>
      <div id="header-team-badge" class="hidden items-center border-l border-slate-800 pl-4">
        <span id="header-team-name" class="text-[10px] uppercase tracking-widest font-bold text-cyan-500 bg-cyan-950/30 px-2 py-1 rounded border border-cyan-800/30">
          Loading...
        </span>
      </div>
    </div>

    <div id="auth-zone" class="flex items-center">
      <a href="/login" id="login-link" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">
        Log In
      </a>

      <div id="user-profile-zone" class="hidden relative">
        <button id="profile-menu-btn" class="flex items-center gap-3 p-1 rounded-full hover:bg-slate-800/50 transition-all border border-transparent hover:border-slate-700">
          <span id="user-name-display" class="hidden md:block text-sm font-medium text-slate-300 ml-2"></span>
          <img id="user-photo" src="" alt="Profile" class="w-8 h-8 rounded-full border border-cyan-500/50 object-cover" />
        </button>

        <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-48 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl overflow-hidden animate-in fade-in zoom-in-95 duration-100">
          <div class="px-4 py-3 border-b border-slate-800">
            <p class="text-xs text-slate-500">Signed in as</p>
            <p id="user-email-display" class="text-xs font-semibold text-slate-200 truncate"></p>
          </div>
          <button id="logout-btn" class="w-full text-left px-4 py-3 text-sm text-red-400 hover:bg-red-500/10 transition-colors font-semibold">
            Log Out
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  import { auth, db } from '../lib/firebase';
  import { signOut, onAuthStateChanged } from "firebase/auth";
  import { ref, get } from "firebase/database";

  const loginLink = document.getElementById('login-link');
  const userProfileZone = document.getElementById('user-profile-zone');
  const profileMenuBtn = document.getElementById('profile-menu-btn');
  const profileDropdown = document.getElementById('profile-dropdown');
  const logoutBtn = document.getElementById('logout-btn');
  
  const userNameDisplay = document.getElementById('user-name-display');
  const userEmailDisplay = document.getElementById('user-email-display');
  const userPhoto = document.getElementById('user-photo') as HTMLImageElement;
  const teamBadge = document.getElementById('header-team-badge');
  const teamNameEl = document.getElementById('header-team-name');

  // Toggle Dropdown
  profileMenuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    profileDropdown?.classList.toggle('hidden');
  });

  // Close dropdown when clicking outside
  window.addEventListener('click', () => profileDropdown?.classList.add('hidden'));

  onAuthStateChanged(auth, async (user) => {
    if (user) {
      // Switch UI to Logged In
      loginLink?.classList.add('hidden');
      userProfileZone?.classList.remove('hidden');
      
      // Set User Data
      if (userNameDisplay) userNameDisplay.textContent = user.displayName;
      if (userEmailDisplay) userEmailDisplay.textContent = user.email;
      if (userPhoto) userPhoto.src = user.photoURL || `https://ui-avatars.com/api/?name=${user.displayName}&background=06b6d4&color=fff`;

      // Fetch Team Context
      const userSnap = await get(ref(db, `users/${user.uid}`));
      const userData = userSnap.val();

      if (userData?.teamId) {
        const teamSnap = await get(ref(db, `teams/${userData.teamId}`));
        if (teamNameEl) teamNameEl.textContent = teamSnap.val()?.name.toUpperCase() || "MY TEAM";
        teamBadge?.classList.remove('hidden');
        teamBadge?.classList.add('flex');
      }
    } else {
      // Switch UI to Logged Out
      loginLink?.classList.remove('hidden');
      userProfileZone?.classList.add('hidden');
      teamBadge?.classList.add('hidden');
    }
  });

  logoutBtn?.addEventListener('click', async () => {
    await signOut(auth);
    window.location.href = '/login';
  });
</script>