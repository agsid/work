        <a href="/dash/scorer" class="nav-link group flex items-center gap-2 px-3 py-2 md:px-4 md:py-3 rounded-xl transition-all duration-200 text-[11px] md:text-sm font-bold text-zinc-400 hover:text-white hover:bg-white/5">
            <span>Scorer</span>
            <div class="indicator w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-indigo-500 opacity-0 transition-opacity"></div>
