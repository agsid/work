<script>
    import { auth, rtdb } from "../lib/firebase";
    import { ref, get, child } from "firebase/database";
    import { onAuthStateChanged, signOut } from "firebase/auth";

    // --- 1. ACTIVE STATE UI ---
    const setActiveLink = () => {
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');
            // Exact match or sub-path match for active state
            if (href && (currentPath === href || currentPath.startsWith(href + '/'))) {
                link.classList.add('bg-white/10', 'text-white');
                link.classList.remove('text-zinc-400');
                link.querySelector('.indicator')?.classList.remove('opacity-0');
            }
        });
    };

    // --- 2. FIREBASE DATA SYNC ---
    onAuthStateChanged(auth, async (user) => {
        if (!user) return;

        const nameEl = document.getElementById('userName');
        const initialEl = document.getElementById('userInitials');
        const teamEl = document.getElementById('teamLabel');
        const manageLink = document.getElementById('manageTeamLink');

        if (nameEl) nameEl.textContent = user.displayName || user.email?.split('@')[0] || "User";
        if (initialEl) {
            const namePart = user.displayName || user.email || "U";
            initialEl.textContent = namePart[0].toUpperCase();
        }

        try {
            const dbRef = ref(rtdb);
            const userSnap = await get(child(dbRef, `users/${user.uid}`));
            
            if (userSnap.exists()) {
                const userData = userSnap.val();
                
                if (userData.team) {
                    const teamSnap = await get(child(dbRef, `teams/${userData.team}`));
                    if (teamSnap.exists()) {
                        const teamData = teamSnap.val();
                        if (teamEl) teamEl.textContent = teamData.name;
                        
                        if (teamData.owner === user.uid) {
                            manageLink?.classList.remove('hidden');
                            manageLink?.classList.add('md:flex');
                        }
                    }
                } else {
                    if (teamEl) teamEl.textContent = "Personal ARK";
                }
            }
        } catch (err) {
            console.error("Sidebar data sync error:", err);
        }
    });

    // --- 3. LOGOUT ---
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await signOut(auth);
        window.location.href = "/login";
    });

    setActiveLink();
</script>