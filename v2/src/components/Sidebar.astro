        <a href="/editor/dashboard" class="nav-link group flex items-center gap-2 px-3 py-2 md:px-4 md:py-3 rounded-xl transition-all duration-200 text-[11px] md:text-sm font-bold text-zinc-400 hover:text-white hover:bg-white/5">
            <span>Files</span>
