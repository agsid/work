    <div>
        <div class="mb-10 hidden md:block">
            <div class="flex items-center gap-2 mb-1">
                <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 shadow-[0_0_8px_var(--color-indigo-500)]"></div>
                <h1 class="text-[10px] font-black uppercase tracking-[0.4em] text-white/90">AlliedDash</h1>
            </div>
            <h2 id="sideTeamName" class="text-xl md:text-2xl font-black italic tracking-tighter text-indigo-500 uppercase leading-none ml-1">
                Loading...
