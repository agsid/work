<style is:global>
    @reference "../styles/global.css";
    .nav-link { @apply relative flex items-center justify-between px-5 py-3.5 rounded-2xl transition-all duration-300 text-[11px] font-black uppercase tracking-widest text-zinc-500 hover:text-white hover:bg-white/5; }
    .nav-link.active { @apply bg-white/5 text-white; }
    .indicator { @apply w-1 h-1 rounded-full bg-indigo-500 shadow-[0_0_8px_var(--color-indigo-500)] opacity-0 transition-all duration-300 scale-0; }
    .nav-link.active .indicator { @apply opacity-100 scale-100; }
</style>

<script>
    import { auth, rtdb } from "../lib/firebase";
    import { ref, onValue, get, child } from "firebase/database";
    import { onAuthStateChanged, signOut } from "firebase/auth";

    const updateActiveState = () => {
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');
            if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
                link.classList.add('active');
            } else {
                link.classList.remove('active');
            }
        });
    };

    onAuthStateChanged(auth, async (user) => {
        if (!user) return;
        
        const teamNameEl = document.getElementById('sideTeamName');
        const manageBtn = document.getElementById('sideManageBtn');
        const arkLink = document.getElementById('arkNavLink');
        const nameEl = document.getElementById('userName');
        const rankEl = document.getElementById('userRank');
        const initialEl = document.getElementById('userInitials');
        const photoEl = document.getElementById('userPhoto') as HTMLImageElement;

        if (nameEl) nameEl.textContent = user.displayName || user.email?.split('@')[0];
        if (user.photoURL) {
            if (photoEl) { photoEl.src = user.photoURL; photoEl.classList.remove('hidden'); }
            if (initialEl) initialEl.classList.add('hidden');
        } else {
            if (initialEl) initialEl.textContent = (user.displayName || user.email || "U").substring(0, 2).toUpperCase();
        }

        const userSnap = await get(child(ref(rtdb), `users/${user.uid}`));
        if (userSnap.exists()) {
            const userData = userSnap.val();
            
            if (rankEl) {
                const isRank2 = userData.rank === 2;
                rankEl.textContent = isRank2 ? "Rank 2" : "Rank 1";
                rankEl.classList.replace('text-zinc-600', isRank2 ? 'text-indigo-400' : 'text-zinc-500');
            }

            if (userData.team) {
                onValue(ref(rtdb, `teams/${userData.team}`), (snapshot) => {
                    const teamData = snapshot.val();
                    if (!teamData) return;
                    if (teamNameEl) teamNameEl.textContent = teamData.name;
                    
                    if (teamData.arkEnabled) { arkLink?.classList.remove('hidden'); arkLink?.classList.add('flex'); }
                    else { arkLink?.classList.add('hidden'); }

                    if (teamData.owner === user.uid || userData.rank === 2) {
                        manageBtn?.classList.remove('hidden');
                        manageBtn?.classList.add('flex');
                    }
                });
            } else {
                if (teamNameEl) teamNameEl.textContent = "Personal ARK";
            }
        }
    });

    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        if (confirm("Logout from AlliedDash?")) {
            await signOut(auth);
            window.location.href = "/login";
        }
    });

    updateActiveState();
</script>