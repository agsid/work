<header class="w-full bg-zinc-900/20 border border-white/5 rounded-[2rem] px-8 py-4 mb-6 flex justify-between items-center backdrop-blur-md">
    <div class="flex items-center gap-4">
        <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
        <h2 class="text-xs font-black uppercase tracking-[0.3em] text-white/50">AlliedDash <span class="text-white/20 mx-2">//</span> <span class="text-white">System Active</span></h2>
    </div>

    <div class="flex items-center gap-4">
        <div class="text-right hidden sm:block">
            <p id="headerUserName" class="text-xs font-black text-white uppercase tracking-tight">Loading Persona...</p>
            <p id="headerUserRank" class="text-[8px] text-zinc-600 font-bold uppercase tracking-widest">Verifying Clearance</p>
        </div>
        <div id="headerInitials" class="w-10 h-10 rounded-xl bg-white text-black flex items-center justify-center font-black italic text-xs shadow-lg shadow-white/5">
            --
        </div>
    </div>
</header>

<script>
    import { auth, rtdb } from "../lib/firebase";
    import { ref, get, child } from "firebase/database";
    import { onAuthStateChanged } from "firebase/auth";

    onAuthStateChanged(auth, async (user) => {
        if (!user) return;
        
        const nameEl = document.getElementById('headerUserName');
        const initialEl = document.getElementById('headerInitials');
        const rankEl = document.getElementById('headerUserRank');

        if (nameEl) nameEl.textContent = user.displayName || user.email?.split('@')[0];
        if (initialEl) initialEl.textContent = (user.displayName || user.email || "U").substring(0, 2).toUpperCase();

        const userSnap = await get(child(ref(rtdb), `users/${user.uid}`));
        if (userSnap.exists() && rankEl) {
            const rank = userSnap.val().rank || 1;
            rankEl.textContent = rank === 2 ? "Level 2: Command" : "Level 1: Operative";
            rankEl.classList.add(rank === 2 ? 'text-indigo-400' : 'text-zinc-600');
        }
    });
</script>