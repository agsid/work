---
import Layout from '../layouts/Layout.astro'
import Sidebar from '../components/Sidebar.astro'
---

<Layout title="AlliedWork – Resources">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col md:flex-row p-4 md:p-6 gap-4 md:gap-6">
    
    <div id="sidebar-container" class="w-full md:w-1/6 md:h-[calc(100vh-3rem)] md:sticky md:top-6 z-50">
        <Sidebar />
    </div>

    <main class="flex-1 bg-zinc-900/20 border border-white/5 rounded-[2rem] md:rounded-[3rem] p-6 md:p-12 overflow-y-auto backdrop-blur-sm no-scrollbar relative">
      
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-10 md:mb-16 gap-4">
        <div>
          <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">Saved Links</h2>
          <p class="text-zinc-500 text-[10px] md:text-xs mt-2 font-bold uppercase tracking-[0.3em]">Team Resources</p>
        </div>
        <button id="openLinkModal" class="w-full sm:w-auto px-8 py-4 bg-white text-black rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-zinc-200 transition active:scale-95 shadow-lg shadow-white/5">
          + Add Link
        </button>
      </div>

      <div id="linksGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          </div>

      <div id="linkModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-md p-4">
        <div class="glass w-full max-w-md rounded-[2.5rem] p-8 md:p-10 shadow-2xl border border-white/10">
          <h3 class="text-xl font-black italic mb-6 tracking-tighter uppercase">New Resource</h3>
          
          <div class="space-y-5">
            <div>
              <label class="label-style">Link Title</label>
              <input id="link_title" type="text" placeholder="e.g. GitHub Repository" class="input-style">
            </div>
            <div>
              <label class="label-style">URL</label>
              <input id="link_url" type="url" placeholder="https://..." class="input-style">
            </div>
          </div>

          <div class="flex gap-3 mt-10">
            <button id="closeLinkModal" class="flex-1 px-6 py-4 border border-white/10 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-white/5 transition text-zinc-500">Cancel</button>
            <button id="saveLinkBtn" class="flex-1 px-6 py-4 bg-indigo-600 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-indigo-500 transition shadow-lg shadow-indigo-500/20">Save Link</button>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  @reference "../styles/global.css";

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .glass { background: rgba(12, 12, 12, 0.85); backdrop-filter: blur(20px); }
  
  .label-style {
    @apply text-[9px] text-zinc-600 font-black uppercase tracking-[0.2em] ml-1 mb-2 block;
  }

  .input-style {
    @apply w-full bg-black/40 border border-white/10 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo-500 transition text-sm text-white placeholder:text-zinc-800;
  }
</style>

<script>
    import { auth, rtdb } from "../lib/firebase";
    import { ref, push, get, remove, query, orderByChild, equalTo, onValue } from "firebase/database";
    import { onAuthStateChanged } from "firebase/auth";

    const linksGrid = document.getElementById('linksGrid');
    const linkModal = document.getElementById('linkModal');
    
    let currentTeamId = "";
    let userRank = 1;

    // --- AUTH OBSERVER ---
    onAuthStateChanged(auth, async (user) => {
      if (!user) return window.location.href = "/login";
      
      const userSnap = await get(ref(rtdb, `users/${user.uid}`));
      if (userSnap.exists()) {
        const userData = userSnap.val();
        currentTeamId = userData.team;
        userRank = userData.rank || 1;
        
        if (!currentTeamId) {
            window.location.href = "/team";
            return;
        }
        syncLinks();
      }
    });

    // --- REALTIME SYNC ---
    function syncLinks() {
      const linksRef = query(ref(rtdb, 'links'), orderByChild('team'), equalTo(currentTeamId));
      onValue(linksRef, (snapshot) => {
        const data = snapshot.val();
        if (!data) {
          linksGrid!.innerHTML = `<div class="col-span-full py-20 text-center text-zinc-700 uppercase text-[10px] font-black tracking-widest">No resources cataloged</div>`;
          return;
        }

        const links = Object.keys(data).map(id => ({ ...data[id], id }));
        renderLinks(links.reverse());
      });
    }

    function renderLinks(links: any[]) {
      linksGrid!.innerHTML = links.map(l => {
        const displayUrl = l.url.replace(/^https?:\/\//, '').split('/')[0];
        
        return `
        <div class="group p-8 bg-zinc-900/30 border border-white/5 rounded-[2.5rem] hover:border-indigo-500/30 transition-all flex flex-col justify-between min-h-[180px] relative overflow-hidden">
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <div class="p-2.5 bg-indigo-500/10 rounded-xl border border-indigo-500/20">
                  <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
              </div>
              ${userRank === 2 ? `
                <button onclick="window.deleteLink('${l.id}')" class="opacity-0 group-hover:opacity-100 text-[9px] text-zinc-600 hover:text-red-500 uppercase font-black tracking-widest transition-all">Terminate</button>
              ` : ''}
            </div>
            <h3 class="text-lg font-black italic tracking-tight text-white mb-1 group-hover:text-indigo-400 transition-colors uppercase leading-tight">${l.title}</h3>
            <p class="text-zinc-600 text-[10px] font-mono tracking-tighter truncate">${displayUrl}</p>
          </div>
          
          <a href="${l.url}" target="_blank" class="mt-8 flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-500 group-hover:text-white transition-all">
              Launch Source 
              <svg class="w-3 h-3 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
          
          <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-indigo-600/5 blur-[50px] rounded-full group-hover:bg-indigo-600/10 transition-all"></div>
        </div>`;
      }).join('');
    }

    // --- ACTIONS ---
    (window as any).deleteLink = (id: string) => {
      if(confirm("Permanently terminate this resource record?")) {
        remove(ref(rtdb, `links/${id}`));
      }
    };

    document.getElementById('openLinkModal')?.addEventListener('click', () => linkModal?.classList.remove('hidden'));
    document.getElementById('closeLinkModal')?.addEventListener('click', () => linkModal?.classList.add('hidden'));

    document.getElementById('saveLinkBtn')?.addEventListener('click', async () => {
      const title = (document.getElementById('link_title') as HTMLInputElement).value;
      const url = (document.getElementById('link_url') as HTMLInputElement).value;

      if (!title || !url) return alert("System requires Title and URL");

      try {
        await push(ref(rtdb, 'links'), {
          title,
          url,
          team: currentTeamId,
          created: Date.now()
        });
        
        // Reset and close
        (document.getElementById('link_title') as HTMLInputElement).value = "";
        (document.getElementById('link_url') as HTMLInputElement).value = "";
        linkModal?.classList.add('hidden');
      } catch (err) {
        console.error("Link persistence failed");
      }
    });
</script>