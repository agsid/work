---
import Layout from '../layouts/Layout.astro'
import Sidebar from '../components/Sidebar.astro'
---

<Layout title="AlliedWork – Team Operations">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col md:flex-row p-4 md:p-6 gap-4 md:gap-6">
    
    <div id="sidebar-container" class="w-full md:w-1/6 md:h-[calc(100vh-3rem)] md:sticky md:top-6 z-50">
        <Sidebar />
    </div>

    <main class="flex-1 bg-zinc-900/20 border border-white/5 rounded-[2rem] md:rounded-[3rem] p-6 md:p-12 overflow-y-auto backdrop-blur-sm no-scrollbar relative">
      
      <div id="confirmModal" class="hidden fixed inset-0 z-[110] flex items-center justify-center bg-black/95 backdrop-blur-md p-4">
          <div class="glass w-full max-w-sm rounded-[2rem] p-8 shadow-2xl text-center border border-indigo-500/30">
              <div class="w-14 h-14 bg-indigo-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              </div>
              <h4 class="text-xl font-black italic uppercase tracking-tighter mb-2 text-white">Confirm ARK Link</h4>
              <p class="text-zinc-500 text-[10px] uppercase font-bold tracking-widest mb-8 leading-relaxed">Authorize high-frequency hardware bridge for this division?</p>
              <div class="flex gap-3">
                  <button id="cancelConfirm" class="flex-1 py-4 rounded-xl border border-white/10 text-[10px] font-black uppercase tracking-widest text-zinc-500 hover:bg-white/5 transition">Abort</button>
                  <button id="authorizeConfirm" class="flex-1 py-4 rounded-xl bg-indigo-600 text-white text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/40 active:scale-95 transition">Confirm</button>
              </div>
          </div>
      </div>

      <div id="customPrompt" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
          <div class="glass w-full max-w-sm rounded-[2.5rem] p-10 shadow-2xl text-center border border-white/5">
              <h4 id="promptTitle" class="text-2xl font-black italic uppercase tracking-tighter mb-2">Initialize</h4>
              <p id="promptSub" class="text-zinc-500 text-[10px] uppercase font-bold tracking-widest mb-8">System parameters required</p>
              <input id="promptInput" type="text" class="w-full bg-black/40 border border-white/10 rounded-2xl px-5 py-4 text-sm text-white focus:outline-none focus:border-indigo-500 mb-8 text-center placeholder:text-zinc-700" placeholder="Identifier...">
              <div class="flex gap-3">
                  <button id="closePromptBtn" class="flex-1 py-4 rounded-xl border border-white/10 text-[10px] font-black uppercase tracking-widest text-zinc-500">Cancel</button>
                  <button id="promptConfirm" class="flex-1 py-4 rounded-xl bg-white text-black text-[10px] font-black uppercase tracking-widest font-bold">Authorize</button>
              </div>
          </div>
      </div>

      <div id="noTeamView" class="hidden text-center py-20">
        <h2 class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter mb-4">No Division</h2>
        <p class="text-zinc-600 mb-12 max-w-md mx-auto uppercase text-[10px] tracking-[0.4em] font-bold">Authentication failed: Join a team to proceed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-6">
          <button id="openCreateBtn" class="px-12 py-5 bg-white text-black rounded-2xl font-bold hover:scale-105 transition shadow-2xl text-xs uppercase tracking-widest">Create Team</button>
          <button id="openJoinBtn" class="px-12 py-5 bg-zinc-900 border border-white/10 rounded-2xl font-bold hover:bg-zinc-800 transition text-xs uppercase tracking-widest">Join Team</button>
        </div>
      </div>

      <div id="teamView" class="hidden">
        <div class="flex gap-10 border-b border-white/5 mb-12">
            <button id="tabRoster" class="tab-btn active">Personnel</button>
            <button id="tabSettings" class="tab-btn">Settings</button>
        </div>

        <div id="viewRoster" class="space-y-12">
            <div class="mb-12">
                <h2 id="teamNameHeader" class="text-5xl md:text-8xl font-black italic uppercase tracking-tighter mb-8 leading-none truncate text-indigo-500">TEAM</h2>
                <div class="flex flex-col md:flex-row items-start md:items-center gap-6 bg-zinc-900/40 border border-white/5 p-8 md:p-10 rounded-[2.5rem] backdrop-blur-sm">
                    <div class="flex-1 w-full">
                        <p class="text-zinc-600 text-[10px] uppercase font-black tracking-[0.4em] mb-3">Encrypted Invite Token</p>
                        <code id="joinCodeText" class="text-3xl md:text-4xl font-mono text-indigo-400 tracking-[0.2em] uppercase">------</code>
                    </div>
                    <button id="copyBtn" class="w-full md:w-auto px-10 py-5 bg-white/5 border border-white/10 rounded-2xl font-bold hover:bg-white/10 hover:border-white/20 transition text-[10px] uppercase tracking-widest">Copy Identifier</button>
                </div>
            </div>

            <div class="space-y-6">
                <div class="flex justify-between items-center border-b border-white/5 pb-5">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.5em] text-zinc-700">Active Division Roster</h3>
                    <span id="rosterCount" class="text-[9px] bg-indigo-500/10 text-indigo-400 px-4 py-1.5 rounded-full border border-indigo-500/20 font-black uppercase tracking-widest">0 Members</span>
                </div>
                <div id="memberList" class="grid grid-cols-1 gap-4">
                    </div>
            </div>
        </div>

        <div id="viewSettings" class="hidden space-y-10">
            <div class="max-w-3xl">
                <h3 class="text-3xl font-black italic uppercase tracking-tighter mb-2">Division Override</h3>
                <p class="text-zinc-600 text-[10px] uppercase tracking-[0.3em] font-black mb-10">Administrative Clearance Level 2 Required</p>

                <div class="grid grid-cols-1 gap-6">
                    <div class="flex items-center justify-between p-8 bg-zinc-900/40 border border-white/5 rounded-[2.5rem] transition-all hover:bg-zinc-900/60">
                        <div class="flex items-center gap-6">
                            <div class="w-12 h-12 bg-indigo-500/10 rounded-2xl flex items-center justify-center border border-indigo-500/20">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                            </div>
                            <div>
                                <p class="text-sm font-black text-white uppercase tracking-widest">ARK Integration</p>
                                <p class="text-[10px] text-zinc-600 font-bold mt-1 uppercase tracking-wider leading-relaxed">Deploy external hardware telemetry bridge</p>
                            </div>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="arkToggle" class="sr-only peer">
                            <div class="w-14 h-7 bg-zinc-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-zinc-600 after:rounded-full after:h-5 after:w-6 after:transition-all peer-checked:bg-indigo-600 peer-checked:after:bg-white peer-checked:after:translate-x-7"></div>
                        </label>
                    </div>

                    <div class="p-8 bg-zinc-900/20 border border-white/5 rounded-[2.5rem] border-dashed opacity-40">
                        <p class="text-[10px] text-zinc-700 font-black uppercase tracking-[0.4em] text-center">Additional System Modules Encrypted</p>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  @reference "../styles/global.css";

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .glass { background: rgba(12, 12, 12, 0.85); backdrop-filter: blur(24px); }
  
  .tab-btn { @apply pb-5 text-[11px] font-black uppercase tracking-[0.4em] text-zinc-700 transition-all border-b-2 border-transparent; }
  .tab-btn.active { @apply text-indigo-500 border-indigo-500; }
  
  .rank-pill { @apply text-[8px] font-black uppercase px-3 py-1 rounded-full border transition-all tracking-widest; }
  .rank-1 { @apply border-zinc-800 text-zinc-600 bg-zinc-900/50; }
  .rank-2 { @apply border-indigo-500/30 text-indigo-400 bg-indigo-500/10 shadow-[0_0_15px_var(--color-indigo-500/0.1)]; }
</style>

<script>
    import { auth, rtdb } from "../lib/firebase";
    import { ref, set, get, child, update, query, orderByChild, equalTo } from "firebase/database";
    import { onAuthStateChanged } from "firebase/auth";

    // --- DOM REFERENCES ---
    const noTeamView = document.getElementById('noTeamView');
    const teamView = document.getElementById('teamView');
    const teamNameHeader = document.getElementById('teamNameHeader');
    const joinCodeText = document.getElementById('joinCodeText');
    const rosterCount = document.getElementById('rosterCount');
    const memberList = document.getElementById('memberList');
    
    const views = { roster: document.getElementById('viewRoster'), settings: document.getElementById('viewSettings') };
    const tabs = { roster: document.getElementById('tabRoster'), settings: document.getElementById('tabSettings') };
    
    const customPrompt = document.getElementById('customPrompt');
    const promptInput = document.getElementById('promptInput') as HTMLInputElement;
    const promptConfirm = document.getElementById('promptConfirm');
    
    const arkToggle = document.getElementById('arkToggle') as HTMLInputElement;
    const confirmModal = document.getElementById('confirmModal');

    let currentUserId = "";
    let currentTeamId = "";
    let currentUserRank = 1;

    // --- AUTH OBSERVER ---
    onAuthStateChanged(auth, (user) => {
      if (!user) {
        window.location.href = "/login";
      } else {
        currentUserId = user.uid;
        loadUserTeam();
      }
    });

    // --- DATA LOADING ---
    async function loadUserTeam() {
      const dbRef = ref(rtdb);
      const userSnap = await get(child(dbRef, `users/${currentUserId}`));
      
      if (userSnap.exists() && userSnap.val().team) {
        currentTeamId = userSnap.val().team;
        currentUserRank = userSnap.val().rank || 1;

        const teamSnap = await get(child(dbRef, `teams/${currentTeamId}`));
        if (teamSnap.exists()) {
          const teamData = teamSnap.val();
          teamView?.classList.remove('hidden');
          if(teamNameHeader) teamNameHeader.textContent = teamData.name;
          if(joinCodeText) joinCodeText.textContent = teamData.joinCode;
          if(arkToggle) arkToggle.checked = teamData.arkEnabled || false;
          
          loadRoster(currentTeamId);
        }
      } else {
        noTeamView?.classList.remove('hidden');
      }
    }

    async function loadRoster(teamId: string) {
      const usersRef = ref(rtdb, 'users');
      const teamQuery = query(usersRef, orderByChild('team'), equalTo(teamId));
      const snapshot = await get(teamQuery);
      
      if (snapshot.exists()) {
        const data = snapshot.val();
        const members = Object.keys(data).map(uid => ({ ...data[uid], uid }));
        if(rosterCount) rosterCount.textContent = `${members.length} Members`;
        
        if(memberList) {
            memberList.innerHTML = members.map((m: any) => `
                <div class="flex items-center justify-between p-6 bg-zinc-900/30 border border-white/5 rounded-3xl group transition-all hover:bg-zinc-900/50 hover:border-white/10">
                    <div class="flex items-center gap-5">
                        <div class="w-12 h-12 rounded-2xl bg-zinc-800 flex items-center justify-center font-black text-xs text-zinc-600 uppercase border border-white/5 group-hover:text-indigo-400 group-hover:border-indigo-500/20 transition-all">
                            ${(m.email || '??').substring(0,2)}
                        </div>
                        <div>
                            <div class="flex items-center gap-3">
                                <p class="font-bold text-sm text-zinc-200">${m.email.split('@')[0]}</p>
                                <span class="rank-pill ${m.rank === 2 ? 'rank-2' : 'rank-1'}">
                                    ${m.rank === 2 ? 'Rank 2: Command' : 'Rank 1: Member'}
                                </span>
                            </div>
                            <p class="text-[10px] text-zinc-600 font-mono mt-1">${m.email}</p>
                        </div>
                    </div>
                    
                    ${currentUserRank === 2 ? `
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0">
                            <button onclick="window.promoteUser('${m.uid}', ${m.rank === 2 ? 1 : 2})" class="px-5 py-2.5 bg-white/5 hover:bg-indigo-600 hover:text-white border border-white/10 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all">
                                ${m.rank === 2 ? 'Demote' : 'Promote'}
                            </button>
                        </div>
                    ` : `
                        <span class="text-[8px] text-zinc-800 uppercase font-black tracking-[0.2em] opacity-50">Secured</span>
                    `}
                </div>
            `).join('');
        }
      }
    }

    // --- TAB LOGIC ---
    tabs.roster?.addEventListener('click', () => switchTab('roster'));
    tabs.settings?.addEventListener('click', () => {
        if(currentUserRank < 2) return alert("RANK 2 CLEARANCE REQUIRED FOR SYSTEM OVERRIDE");
        switchTab('settings');
    });

    function switchTab(target: 'roster' | 'settings') {
        Object.values(views).forEach(v => v?.classList.add('hidden'));
        Object.values(tabs).forEach(t => t?.classList.remove('active'));
        views[target]?.classList.remove('hidden');
        tabs[target]?.classList.add('active');
    }

    // --- ARK SETTINGS LOGIC ---
    arkToggle?.addEventListener('change', (e) => {
        const checked = (e.target as HTMLInputElement).checked;
        if (checked) {
            confirmModal?.classList.remove('hidden');
            arkToggle.checked = false; // Reset visually until confirmed
        } else {
            updateArkStatus(false);
        }
    });

    document.getElementById('cancelConfirm')?.addEventListener('click', () => confirmModal?.classList.add('hidden'));
    document.getElementById('authorizeConfirm')?.addEventListener('click', async () => {
        await updateArkStatus(true);
        confirmModal?.classList.add('hidden');
        arkToggle.checked = true;
    });

    async function updateArkStatus(enabled: boolean) {
        if (!currentTeamId) return;
        await update(ref(rtdb, `teams/${currentTeamId}`), { arkEnabled: enabled });
    }

    // --- GLOBAL ACTIONS ---
    (window as any).promoteUser = async (targetUid: string, newRank: number) => {
        if (targetUid === currentUserId) return alert("CRITICAL ERROR: SELF-DEMOTION BLOCKED");
        try {
            await update(ref(rtdb, `users/${targetUid}`), { rank: newRank });
            window.location.reload();
        } catch (e) { alert("UPDATE FAILED"); }
    };

    // --- PROMPT LOGIC ---
    const openPrompt = (mode: 'create' | 'join') => {
        customPrompt?.classList.remove('hidden');
        promptInput.value = "";
        const title = document.getElementById('promptTitle');
        if (mode === 'create') {
            if(title) title.textContent = "Initialize Division";
            promptConfirm!.onclick = () => execCreate(promptInput.value);
        } else {
            if(title) title.textContent = "Link Identifier";
            promptConfirm!.onclick = () => execJoin(promptInput.value);
        }
    };

    const execCreate = async (name: string) => {
        if (!name) return;
        const teamId = Math.random().toString(36).substring(2, 15);
        const joinCode = Math.random().toString(36).substring(2, 8).toUpperCase();
        try {
            await set(ref(rtdb, `teams/${teamId}`), { name, joinCode, owner: currentUserId, arkEnabled: false });
            await update(ref(rtdb, `users/${currentUserId}`), { team: teamId, rank: 2 });
            window.location.reload();
        } catch (e) { alert("INITIALIZATION ERROR"); }
    };

    const execJoin = async (code: string) => {
        if (!code) return;
        const codeQuery = query(ref(rtdb, 'teams'), orderByChild('joinCode'), equalTo(code.toUpperCase()));
        const snapshot = await get(codeQuery);
        if (snapshot.exists()) {
            const teamId = Object.keys(snapshot.val())[0];
            await update(ref(rtdb, `users/${currentUserId}`), { team: teamId, rank: 1 });
            window.location.reload();
        } else { alert("INVALID IDENTIFIER"); }
    };

    // --- EVENT BINDING ---
    document.getElementById('openCreateBtn')?.addEventListener('click', () => openPrompt('create'));
    document.getElementById('openJoinBtn')?.addEventListener('click', () => openPrompt('join'));
    document.getElementById('closePromptBtn')?.addEventListener('click', () => customPrompt?.classList.add('hidden'));
    document.getElementById('copyBtn')?.addEventListener('click', () => {
        navigator.clipboard.writeText(joinCodeText?.textContent || "");
        const btn = document.getElementById('copyBtn');
        if(btn) { btn.textContent = "COPIED"; setTimeout(() => btn.textContent = "COPY IDENTIFIER", 2000); }
    });
</script>