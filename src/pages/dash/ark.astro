---
import Layout from '../../layouts/Layout.astro'
import Sidebar from '../../components/Sidebar.astro'
---

<Layout title="ARK | Allied Relic Keeper">
  <div class="flex flex-col md:flex-row min-h-screen p-4 md:p-6 gap-6 bg-[#050505]">
    
    <aside class="w-full md:w-80 shrink-0">
      <Sidebar />
    </aside>

    <main class="flex-1 bg-zinc-900/20 border border-white/5 rounded-[3rem] p-8 md:p-12 backdrop-blur-xl relative overflow-hidden">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6 relative z-10">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="px-2 py-0.5 bg-indigo-500/20 border border-indigo-500/30 rounded text-[9px] font-black text-indigo-400 uppercase tracking-widest">Active Module</span>
            <span class="text-zinc-600 text-[9px] font-black uppercase tracking-widest">v2.4.0</span>
          </div>
          <h1 class="text-5xl font-black italic tracking-tighter text-white uppercase">ARK Hub</h1>
          <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-[0.4em] mt-2">Allied Relic Keeper // Secure Vault</p>
        </div>
        
        <div class="flex gap-3">
            <div class="text-right hidden sm:block">
                <p class="text-[9px] text-zinc-600 font-black uppercase">Vault Status</p>
                <p class="text-xs font-black text-emerald-500 uppercase tracking-tighter">Encrypted & Locked</p>
            </div>
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">
        
        <a href="/dash/ark/vault" class="ark-card group">
            <div class="mb-4 p-3 bg-white/5 rounded-2xl w-fit group-hover:bg-indigo-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <h3 class="text-lg font-black uppercase italic tracking-tight mb-1">Secure Vault</h3>
            <p class="text-zinc-500 text-xs leading-relaxed">Store sensitive credentials and mission-critical data with end-to-end encryption.</p>
            <div class="mt-6 flex items-center gap-2 text-[9px] font-black uppercase tracking-widest text-indigo-400">
                Enter Vault <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
        </a>

        <a href="/dash/ark/archives" class="ark-card group">
            <div class="mb-4 p-3 bg-white/5 rounded-2xl w-fit group-hover:bg-indigo-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"></polyline><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path></svg>
            </div>
            <h3 class="text-lg font-black uppercase italic tracking-tight mb-1">Archives</h3>
            <p class="text-zinc-500 text-xs leading-relaxed">Access historical team records, legacy documentation, and project post-mortems.</p>
            <div class="mt-6 flex items-center gap-2 text-[9px] font-black uppercase tracking-widest text-zinc-400">
                Request Access
            </div>
        </a>

        <div class="ark-card opacity-50 cursor-not-allowed border-dashed">
            <div class="mb-4 p-3 bg-white/5 rounded-2xl w-fit">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </div>
            <h3 class="text-lg font-black uppercase italic tracking-tight mb-1">OSINT Tools</h3>
            <p class="text-zinc-500 text-xs leading-relaxed">Open-source intelligence gathering and automated scanning (Coming Soon).</p>
        </div>

      </div>

      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-indigo-600/10 blur-[120px] rounded-full pointer-events-none"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full opacity-[0.02] pointer-events-none overflow-hidden">
        <div class="grid grid-cols-12 h-full w-full">
            {Array.from({length: 144}).map(() => <div class="border-[0.5px] border-white h-20 w-full"></div>)}
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  .ark-card {
    @apply p-8 bg-zinc-900/40 border border-white/5 rounded-[2.5rem] hover:border-indigo-500/40 transition-all flex flex-col relative overflow-hidden;
  }
  
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>